<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Simjot</title>
    <organization>com.s1mplector.simjot</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="false" hostArchitectures="x86_64,arm64"/>
    
    
    
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    
    <choices-outline>
        <line choice="default">
            <line choice="com.s1mplector.simjot"/>
        </line>
    </choices-outline>
    
    <choice id="default"/>
    <choice id="com.s1mplector.simjot" visible="false">
        <pkg-ref id="com.s1mplector.simjot"/>
    </choice>
    
    <pkg-ref id="com.s1mplector.simjot" version="1.0.0" onConclusion="none">component.pkg</pkg-ref>
</installer-gui-script>
